# nlqdb — environment variables
#
# Per DESIGN.md §2.7 this file lists variable NAMES only. Never commit real
# values. Local dev copies this to .envrc (gitignored); CI uses GitHub Actions
# secrets; runtime uses Cloudflare Workers secrets.
#
# Generate real values via: scripts/bootstrap-dev.sh
# Sign in to cloud providers via: scripts/login-cloud.sh

# --- Self-generated (bootstrap-dev.sh) ------------------------------------
BETTER_AUTH_SECRET=
INTERNAL_JWT_SECRET=

# --- Cloudflare (§2.3) ---------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_AI_TOKEN=

# --- Data plane (§2.3) ---------------------------------------------------
# NEON_API_KEY is the Neon *control-plane* API key (mint / list / delete
# projects, branches, databases). DATABASE_URL is the per-project
# Postgres connection string for the current env's main branch.
# Never commit real values. Rotate immediately if either leaks.
NEON_API_KEY=
DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
FLY_API_TOKEN=

# --- LLM providers (§2.4) ------------------------------------------------
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# CF Workers AI is covered by CF_AI_TOKEN above.
# Ollama runs locally, no token required.

# --- OAuth (§2.5) --------------------------------------------------------
# GitHub OAuth uses the `OAUTH_GITHUB_*` prefix because GitHub Actions
# reserves the `GITHUB_*` namespace for built-ins (GITHUB_TOKEN etc.) —
# repo/org secrets prefixed with `GITHUB_` are rejected. Local names
# match CI / Workers names so secret-mirroring is 1:1.
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
# Dev OAuth App (`nlqdb-web-dev`) — separate App because GitHub OAuth
# Apps support exactly one callback URL each; dev uses
# http://localhost:8787/auth/callback/github.
OAUTH_GITHUB_CLIENT_ID_DEV=
OAUTH_GITHUB_CLIENT_SECRET_DEV=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (§2.5) --------------------------------------------------------
RESEND_API_KEY=
# AWS SES fallback was evaluated 2026-04-25 and skipped — card-required,
# and Resend's free tier (3k/mo) covers pre-PMF traffic. If a fallback
# becomes necessary, prefer Postmark / MailerSend / Loops over AWS SES.

# --- Payments (§2.5) — Stripe test mode through Phase 1 -----------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Observability (§2.6) ------------------------------------------------
SENTRY_DSN=
# Grafana Cloud authenticates OTLP pushes via Basic auth where the
# username is the numeric stack instance ID and the password is an
# access policy token. Both are separate for rotation independence.
GRAFANA_OTLP_ENDPOINT=
GRAFANA_CLOUD_INSTANCE_ID=
GRAFANA_CLOUD_API_KEY=
# Plausible is self-hosted on Fly (§2.6) — no SaaS key.
