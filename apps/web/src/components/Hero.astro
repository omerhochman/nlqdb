---
// Goal-first hero (DESIGN §0.1, §3.1, §14.1). The input cycles real
// persona placeholders. Enter routes to /sign-in with the goal
// preserved through the magic-link round-trip:
//   /sign-in?return_to=/app?goal=<encoded>
// After verify, /app reads ?goal= and pre-fills the composer so the
// user lands in the chat with their original intent already typed.

const placeholders = [
  "an orders tracker for my coffee shop",
  "a memory store for my AI agent",
  "a CRM for two-person startups",
  "a leaderboard for our internal hackathon",
  "a feedback inbox with auto-tags",
];
---
<section class="hero">
  <h1 class="hero__wordmark">nlqdb</h1>
  <p class="hero__lede">Natural-language databases.</p>
  <p class="hero__sub">
    Create one in a word. Talk to it in English. The schema, the engine,
    the indexes, the backups — all invisible. The escape hatch to raw
    SQL stays one click away, always.
  </p>

  <form class="heroinput" data-hero-form>
    <input
      type="text"
      class="heroinput__field"
      data-hero-input
      placeholder={placeholders[0]}
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="What are you building?"
    />
    <span class="heroinput__return" aria-hidden="true">⏎</span>
  </form>

  <p class="heroinput__note">
    <span class="dot" aria-hidden="true"></span>
    Pre-alpha — Phase 0 shipped, Phase 1 in progress.
  </p>

  <div class="ctas">
    <a class="btn btn--accent" href="mailto:hello@nlqdb.com">
      Get in touch
    </a>
  </div>

  <aside class="demo" aria-labelledby="demo-caption">
    <p class="demo__caption" id="demo-caption">
      <span class="demo__arrow" aria-hidden="true">↓</span>
      Drop two lines of HTML. That's the entire backend.
    </p>
    <div class="demo__grid">
      <pre class="demo__code"><code>{`<script src="https://elements.nlqdb.com/v1.js" type="module"></script>
<nlq-data
  goal="orders from this morning, by drink"
  db="demo"
  endpoint="https://app.nlqdb.com/v1/demo/ask"
  template="table"
></nlq-data>`}</code></pre>
      <div class="demo__rendered">
        <nlq-data
          goal="orders from this morning, by drink"
          db="demo"
          endpoint="https://app.nlqdb.com/v1/demo/ask"
          template="table"
        ></nlq-data>
      </div>
    </div>
  </aside>
</section>

<script>
  // Workspace import — registers <nlq-data> on the page. Astro
  // bundles this for the static HTML build; the CDN script-tag form
  // shown in the demo snippet is for third-party consumers.
  import "@nlqdb/elements";
</script>

<script is:inline define:vars={{ placeholders }}>
  const input = document.querySelector("[data-hero-input]");
  const form = document.querySelector("[data-hero-form]");

  if (input instanceof HTMLInputElement) {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduced) {
      let i = 0;
      setInterval(() => {
        i = (i + 1) % placeholders.length;
        if (input.value === "") input.placeholder = placeholders[i];
      }, 2800);
    }
  }

  if (form instanceof HTMLFormElement && input instanceof HTMLInputElement) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const goal = input.value.trim();
      // Empty submit: send to plain /sign-in (still useful — auth + /app
      // empty-state guides them). Non-empty: thread the goal through
      // sign-in's `return_to` so /app pre-fills it after the magic-link
      // verify round-trips back.
      const returnTo = goal ? `/app?goal=${encodeURIComponent(goal)}` : "/app";
      location.href = `/sign-in?return_to=${encodeURIComponent(returnTo)}`;
    });
  }
</script>
