---
// Magic-link sign-in page (Slice 10 — DESIGN §4.1, §4.3).
//
// Static Astro page with a bundled-script island. Posts the email to
// Better Auth's magic-link endpoint at the API origin (cross-
// subdomain: nlqdb.com → app.nlqdb.com), then swaps to a "check
// your email" panel. No client framework — the entire form is ~50
// lines of TS bundled by Astro.
//
// `?return_to=` is honored: the magic-link callback URL points back
// at this app's chat surface, with `?return_to=` preserved so the
// callback re-enters the originally requested page.

import Base from "../layouts/Base.astro";
---
<Base
  title="Sign in — nlqdb"
  description="Sign in to nlqdb with a magic link. No passwords."
>
  <div class="page">
    <header class="topnav">
      <a class="topnav__brand" href="/">nlqdb</a>
    </header>

    <main class="signin">
      <h1 class="signin__title">Sign in</h1>
      <p class="signin__lede">A magic link, no passwords. Expires in 15 minutes.</p>

      <div class="signin__social">
        <button type="button" data-social="google" class="signin__oauth signin__oauth--google" aria-label="Sign in with Google">
          {/* Google "G" — official 4-color mark, per
              https://developers.google.com/identity/branding-guidelines.
              Used unmodified; size + button chrome match the
              "neutral / dark" template in the brand guide. */}
          <svg class="signin__oauth-icon" viewBox="0 0 48 48" width="20" height="20" aria-hidden="true">
            <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
            <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
            <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
            <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
          </svg>
          <span>Sign in with Google</span>
        </button>
        <button type="button" data-social="github" class="signin__oauth signin__oauth--github" aria-label="Sign in with GitHub">
          {/* GitHub "Mark" — single-color SVG suitable for dark
              backgrounds when filled with currentColor, per
              https://github.com/logos. Used unmodified in shape. */}
          <svg class="signin__oauth-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.63-5.373-12-12-12"/>
          </svg>
          <span>Sign in with GitHub</span>
        </button>
      </div>

      <div class="signin__divider" role="separator" aria-label="or with email">
        <span>or</span>
      </div>

      <form id="signin-form" class="signin__form">
        <label class="signin__label" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="signin__field"
        />
        <button type="submit" id="signin-submit" class="btn btn--accent signin__submit">
          Send magic link
        </button>
        <p id="signin-error" class="signin__error" hidden></p>
      </form>

      <div id="signin-sent" class="signin__sent" hidden>
        <h2 class="signin__sent-title">Check your email</h2>
        <p class="signin__sent-body">
          We sent a sign-in link to <strong id="signin-sent-email"></strong>.
          Click it within 15 minutes to sign in.
        </p>
        <p class="signin__sent-meta">
          Didn't get it? <button type="button" id="signin-resend" class="signin__link">Send another</button>
          <span id="signin-resend-status" class="signin__resend-status" hidden></span>
        </p>
      </div>
    </main>

    <footer class="foot">
      <span>&copy; nlqdb &middot; Pre-alpha</span>
    </footer>
  </div>

  <script>
    import { APP_BASE, isLikelyEmail, postJson } from "../lib/auth-client";

    const form = document.getElementById("signin-form") as HTMLFormElement;
    const emailInput = document.getElementById("email") as HTMLInputElement;
    const submitBtn = document.getElementById("signin-submit") as HTMLButtonElement;
    const errorEl = document.getElementById("signin-error") as HTMLParagraphElement;
    const sentEl = document.getElementById("signin-sent") as HTMLDivElement;
    const sentEmailEl = document.getElementById("signin-sent-email") as HTMLElement;
    const resendBtn = document.getElementById("signin-resend") as HTMLButtonElement;
    const resendStatus = document.getElementById("signin-resend-status") as HTMLElement;

    const params = new URLSearchParams(location.search);
    const returnTo = params.get("return_to") ?? "/app";
    const callbackURL = new URL(returnTo, APP_BASE).toString();

    type ButtonState = {
      el: HTMLElement;
      idle: string;
      sending: string;
    };

    function setBusy(state: ButtonState, busy: boolean) {
      if (state.el instanceof HTMLButtonElement) {
        state.el.disabled = busy;
      }
      state.el.textContent = busy ? state.sending : state.idle;
    }

    const submitBtnState: ButtonState = {
      el: submitBtn,
      idle: "Send magic link",
      sending: "Sending…",
    };
    const resendBtnState: ButtonState = {
      el: resendBtn,
      idle: "Send another",
      sending: "Sending…",
    };

    async function send(email: string, busyState: ButtonState, options: { showSent: boolean }) {
      errorEl.hidden = true;
      resendStatus.hidden = true;
      setBusy(busyState, true);
      try {
        // `redirectOn401: false` — the sign-in form itself must not
        // redirect to /sign-in on a 401; that would loop. (Better
        // Auth's send endpoint never returns 401 in normal flows;
        // this guards against future plugin chains that could.)
        await postJson(
          "/api/auth/sign-in/magic-link",
          { email, callbackURL },
          { redirectOn401: false },
        );
        sentEmailEl.textContent = email;
        if (options.showSent) {
          form.hidden = true;
          sentEl.hidden = false;
        } else if (busyState === resendBtnState) {
          resendStatus.textContent = "sent";
          resendStatus.hidden = false;
        }
      } catch (err) {
        errorEl.textContent =
          err instanceof Error && err.message ? err.message : "Couldn't send. Try again.";
        errorEl.hidden = false;
      } finally {
        setBusy(busyState, false);
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;
      if (!isLikelyEmail(email)) {
        errorEl.textContent = "That doesn't look like a valid email.";
        errorEl.hidden = false;
        return;
      }
      send(email, submitBtnState, { showSent: true });
    });

    resendBtn.addEventListener("click", () => {
      const email = sentEmailEl.textContent ?? "";
      if (!email) return;
      send(email, resendBtnState, { showSent: false });
    });

    // OAuth init via Better Auth's `POST /api/auth/sign-in/social`,
    // which returns `{ url }` — we top-level-navigate to it. The
    // provider then redirects back to `/api/auth/callback/<provider>`,
    // which sets the session cookie (`.nlqdb.com` scope) and 302s to
    // `callbackURL`.
    for (const btn of document.querySelectorAll<HTMLButtonElement>("[data-social]")) {
      btn.addEventListener("click", async () => {
        const provider = btn.dataset.social;
        if (!provider) return;
        errorEl.hidden = true;
        btn.disabled = true;
        btn.classList.add("signin__oauth--busy");
        try {
          const body = await postJson<{ url?: string; redirect?: boolean }>(
            "/api/auth/sign-in/social",
            { provider, callbackURL },
            { redirectOn401: false },
          );
          if (body.url) {
            location.href = body.url;
            return;
          }
          throw new Error("No redirect URL returned.");
        } catch (err) {
          errorEl.textContent =
            err instanceof Error && err.message ? err.message : "Couldn't start sign-in.";
          errorEl.hidden = false;
          btn.disabled = false;
          btn.classList.remove("signin__oauth--busy");
        }
      });
    }
  </script>

  <style>
    .signin {
      max-width: 420px;
      margin: 0 auto;
      padding: clamp(48px, 10vw, 96px) 0;
    }
    .signin__title {
      font-size: clamp(36px, 6vw, 56px);
      font-weight: 700;
      letter-spacing: -0.04em;
      margin: 0 0 12px;
    }
    .signin__lede {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg-dim);
      margin: 0 0 32px;
    }
    /* OAuth button — Google brand-compliant "dark" variant exactly per
       https://developers.google.com/identity/branding-guidelines:
       40px height, 4px radius, #131314 fill, #8E918F 1px stroke,
       Roboto Medium 14/20, #E3E3E3 text, asymmetric padding
       (12L / 10 between icon+label / 12R / 12V), 20×20 icon
       unmodified. GitHub doesn't publish a comparable brand spec —
       we mirror the same chrome (single-color Octocat fill via
       currentColor is permitted per https://github.com/logos) so
       the two buttons line up visually. */
    .signin__social {
      display: grid;
      gap: 10px;
      margin-bottom: 20px;
    }
    .signin__oauth {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      height: 40px;
      padding: 12px 12px 12px 12px;
      font-family: "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 14px;
      font-weight: 500;
      line-height: 20px;
      letter-spacing: 0.0107em;
      color: #e3e3e3;
      background: #131314;
      border: 1px solid #8e918f;
      border-radius: 4px;
      cursor: pointer;
      transition: background-color 0.2s ease;
    }
    .signin__oauth:hover:not(:disabled) {
      background: #1a1a1b;
    }
    .signin__oauth:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .signin__oauth--busy,
    .signin__oauth:disabled {
      opacity: 0.7;
      cursor: progress;
    }
    .signin__oauth-icon {
      flex-shrink: 0;
    }
    .signin__divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 0 0 20px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--fg-muted);
    }
    .signin__divider::before,
    .signin__divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .signin__form {
      display: grid;
      gap: 12px;
    }
    .signin__label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .signin__field {
      width: 100%;
      padding: 14px 16px;
      font-family: var(--mono);
      font-size: 16px;
      color: var(--fg);
      background: var(--bg-elev);
      border: 3px solid var(--border-strong);
      border-radius: var(--radius);
      box-shadow: var(--shadow-hard);
      outline: none;
    }
    .signin__field:focus {
      border-color: var(--accent);
      box-shadow: var(--shadow-hard-accent);
    }
    .signin__submit {
      justify-content: center;
      margin-top: 8px;
    }
    .signin__error {
      margin: 8px 0 0;
      padding: 10px 12px;
      font-family: var(--mono);
      font-size: 13px;
      color: #ff8a8a;
      background: #2a1212;
      border: 2px solid #ff8a8a;
    }
    .signin__sent {
      padding: 24px;
      border: 3px solid var(--accent);
      background: var(--bg-elev);
      box-shadow: var(--shadow-hard-accent);
    }
    .signin__sent-title {
      font-size: 22px;
      margin: 0 0 12px;
    }
    .signin__sent-body {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg);
      margin: 0 0 16px;
    }
    .signin__sent-meta {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg-dim);
      margin: 0;
    }
    .signin__link {
      background: none;
      border: none;
      color: var(--accent);
      text-decoration: underline;
      font: inherit;
      cursor: pointer;
      padding: 0;
    }
    .signin__link:disabled {
      opacity: 0.6;
      cursor: progress;
    }
    .signin__resend-status {
      margin-left: 8px;
      color: var(--accent);
    }
  </style>
</Base>
